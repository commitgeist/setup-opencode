# answers.env — respostas para modo não-interativo
# Uso: ./setup.sh --answers answers.env
# Copie este arquivo, ajuste, e padronize o time inteiro com um comando.

# Escopo: local (repo atual) | global (~/.config/opencode)
SCOPE=local

# Clouds (separadas por vírgula): AWS, Azure, GCP
CLOUDS="AWS,Azure"

# CI/CD: "Azure Pipelines" | "GitHub Actions" | "GitLab CI" | Nenhum
CICD="Azure Pipelines"
AZDO_ORG=my-org

# IaC: Terraform | Pulumi | CloudFormation | Nenhum
IAC=Terraform

# Kubernetes: Sim | Não
USE_K8S=Sim

# Container Orchestration: AKS | ECS | AKS+ECS | Nenhum
CONTAINER_ORCH="AKS+ECS"

# References (diretório com configs reais de referência): Sim | Não
USE_REFS=Sim

# Bancos (separados por vírgula): PostgreSQL, MySQL, "SQL Server", Nenhum
DBS="PostgreSQL,MySQL"

# Região AWS
AWS_REGION=us-east-1

# Agentes (separados por vírgula): architect, devops-engineer, reviewer, suporte
AGENTS="architect,devops-engineer,reviewer,suporte"

# Tier de modelos: free-zen | free-openrouter | free-ollama | anthropic | openai | custom
MODEL_TIER=free-zen

# Modelos por papel — IDs free mudam com o tempo!
#
# COMO DESCOBRIR OS IDs CORRETOS:
#   opencode models                    # lista todos os providers e modelos
#   opencode models opencode           # só modelos do Zen (inclui free)
#   opencode models huggingface        # só Hugging Face
#   opencode models openrouter         # só OpenRouter
#   opencode models opencode --verbose # com detalhes (custo, limites)
#
# Modelos free no Zen terminam com -free no ID (ex: opencode/deepseek-v4-flash-free)
# Use o ID EXATO do output do comando acima.
#
# Se o modelo configurado não existir, o OpenCode cai pro default — por isso
# dá erro silencioso e carrega outro modelo sem avisar.
MODEL_PLANNER=opencode/kimi-k2.5-free
MODEL_EXECUTOR=opencode/glm-4.7-flash
MODEL_REVIEWER=opencode/glm-4.7-flash
